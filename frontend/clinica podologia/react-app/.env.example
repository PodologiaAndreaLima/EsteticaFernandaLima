# URL base principal da API
VITE_API_BASE_URL=http://localhost:8080

# Opcional: URL base dedicada para o microservico de Ordem de Servico
# Exemplo: http://localhost:8090
VITE_ORDEM_SERVICO_BASE_URL=

# Opcional: sobrescrever por ambiente (fallback quando VITE_API_BASE_URL nao estiver definido)
VITE_API_BASE_URL_DEV=http://localhost:8080
VITE_API_BASE_URL_PROD=https://api.clinicaestetica.com

# Timeout das requisicoes em milissegundos
VITE_API_TIMEOUT_MS=15000

# Endpoint de Ordem de Servico
# Endpoint nativo do microservico
VITE_ORDEM_SERVICO_ENDPOINT=/ordens-servico
